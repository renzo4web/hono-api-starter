# Port for the Node server
PORT=3000

# Runtime mode: development | test | production
NODE_ENV=development

# Optional comma-separated API keys for X-API-Key auth.
# Leave empty to disable auth in local development.
API_KEYS=

# Application logging level: debug | info | warn | error
LOG_LEVEL=info

# RapidAPI proxy secret. Set this to validate requests come through RapidAPI.
# Leave empty for local development.
RAPIDAPI_PROXY_SECRET=
